# ═══ DATABASE (Optional — defaults to local SQLite) ═══
# Get from supabase.com → Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# If left empty, falls back to local SQLite (development only)
DATABASE_URL=sqlite+aiosqlite:///./lifodial.db

# ═══ REQUIRED — Get from aistudio.google.com ═══
GEMINI_API_KEY=

# ═══ REQUIRED for voice calls — cloud.livekit.io ═══
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ═══ Sarvam AI (STT + TTS) ═══
SARVAM_API_KEY=

# ═══ OPTIONAL — Add when going live ═══
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══ OPTIONAL — Real HIS (mock works without) ═══
OXZYGEN_BASE_URL=
OXZYGEN_API_KEY=

# ═══ OPTIONAL — Real phone numbers ═══
VOBIZ_ACCOUNT_SID=
VOBIZ_AUTH_TOKEN=
VOBIZ_SIP_DOMAIN=

# ═══ Notifications ═══
FRONTEND_URL=http://localhost:5173

# ═══ AUTO — Do not change ═══
ENVIRONMENT=development
SECRET_KEY=lifodial_dev_secret_change_in_production
