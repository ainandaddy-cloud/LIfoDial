# Lifodial Frontend — Environment Variables
# Copy this to .env.local for local development, or set in Vercel dashboard for production.

# Backend API URL — points to your locally running backend (or a public tunnel like ngrok)
# For local dev:
VITE_API_URL=http://localhost:8001

# For production (when backend is on your laptop behind ngrok):
# VITE_API_URL=https://your-subdomain.ngrok-free.app
